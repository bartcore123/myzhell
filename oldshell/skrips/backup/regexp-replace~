regexp-replace(){
	integer pcre
	[[ -o re_match_pcre ]] && pcre=1
	emulate -L zsh
	(( pcre )) && setopt re_match_pcre
	4=${(P)1}
	5=
	6=
	local MATCH MBEGIN MEND
	local -a match mbegin mend
	while [[ -n $4 ]]
	do
		if [[ $4 =~ $2 ]]
		then
			5+=${4[1,MBEGIN-1]}${(e)3}
			4=${4[MEND+1,-1]}
			6=1
		else
			break
		fi
	done
	5+=$4
	eval ${1}=${(q)5}
	[[ -n $6 ]]
}
