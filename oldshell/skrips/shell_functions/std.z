shutdown () {
	cd /mnt/c/Users/barth/Desktop
	local shutdown_time
	local shut
	{
		for X
		do
			print -- $X
		done
	} | grep --color=auto -aE -- '[0-9]+' | read shutdown_time
	if [[ -n $shutdown_time ]]
	then
		shut=" /t $shutdown_time" 
	else
		shut="" 
	fi
	set -- ${@//<->/}
	if [[ -n $@ ]]
	then
		set -- ${@//\-/\/}
	else
		set -- "/s"
	fi
	/mnt/c/Windows/System32/cmd.exe "/C" "shutdown ${*}$shut"
}
