#!/bin/zsh

typeset -a macros
macros=()

macro(){
	[[ -n $@ ]] && {
		alias $1
		macros+=(${1%%\=*}) 
	} || {
		alias -L | sed -E 's/^alias \-g/gmacro/' | sed -E 's/alias/macro/' | noglob grep -aE -- "\<(${(j:|:)macros[@]})\="
		return $?
	}
}
gmacro(){
	[[ -n $@ ]] && {
		alias -g $1
		macros+=(${1%%\=*}) 
	} || {
		alias -gL | sed -E 's/alias \-g/gmacro/' | noglob grep -aE -- "\<(${(j:|:)macros[@]})\="
		return $?
	}
}

