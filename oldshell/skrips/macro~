function expand-macro()
{
    if [[ $LBUFFER =~ "\<("${(j:|:)macros[@]//\./\\.}")\$" ]]; then
        zle _expand_alias
    fi
    zle magic-space
}

zle -N expand-macro

bindkey -M main ' '        expand-macro
bindkey -M main '^[ '       magic-space     # alt-space to bypass completion
bindkey -M main '^[^ '       magic-space     # control-alt-space to bypass completion
bindkey -M isearch " "      magic-space     # normal space during searches


